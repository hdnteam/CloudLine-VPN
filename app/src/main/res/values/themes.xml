<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CloudLineVPN" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/cloud_dark_blue</item>
        <item name="android:statusBarColor">@color/cloud_dark_blue</item>
        <item name="android:navigationBarColor">@color/cloud_mid_blue</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.CloudLineVPN.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/cloud_dark_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.CloudLineVPN</item>
    </style>
</resources>
